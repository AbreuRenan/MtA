{
  /* Visit https://firebase.google.com/docs/database/security to learn more about security rules. */
  "rules": {
    ".read": true,
    ".write": false,
    "rollsHistory": {
      ".write": "auth != null"
    },
    "actionLogs": {
      ".write": "auth != null"
    },
    "users": {
      "$uid": {
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'narrador')"
      }
    },
    "yantras": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'narrador'"
    },
    "gameStatus": {
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'narrador'"
    }
  }
}